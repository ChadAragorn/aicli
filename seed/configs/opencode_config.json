{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.ai/cortex.md",
    "~/.ai/plugins/plugins/agent-browser/skills/agent-browser/SKILL.md"
  ],
  "mcp": {
    "engram": {
      "type": "local",
      "command": ["engram", "mcp"],
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env*": "deny",
      ".env*": "deny",
      ".env.local": "allow",
      ".env.example": "allow"
    },
    "edit": {
      "*": "allow",
      "*.env*": "deny",
      ".env*": "deny",
      ".env.local": "allow",
      ".env.example": "allow"
    },
    "glob": {
      "*": "allow",
      "*.env*": "deny",
      ".env*": "deny",
      ".env.local": "allow",
      ".env.example": "allow"
    },
    "list": {
      "*": "allow",
      "*.env*": "deny",
      ".env*": "deny",
      ".env.local": "allow",
      ".env.example": "allow"
    },
    "bash": {
      "*": "allow",
      "* *.env*": "deny",
      "* .env*": "deny",
      "* .env.local*": "allow",
      "* .env.example*": "allow",
      "git push*": "deny",
      "git rebase*": "deny",
      "git filter-repo*": "deny",
      "git clean -fdx*": "deny",
      "git gc --prune=now*": "deny",
      "git merge*": "deny"
    }
  }
}
