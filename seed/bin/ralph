#!/bin/bash
#
# ralph - Loop runner for claude/opencode/kilo CLIs.
# Runs the selected CLI repeatedly with the prompt file until max iterations
# or until the status file indicates "done" or "blocked".
#
# Configuration: environment variables OR command-line arguments (CLI overrides env).
# Optional extra arguments for the underlying CLI can be passed after --.
#
# Environment variables:
#   RALPH_CLI           One of: claude, opencode, kilo (required if not passed)
#   RALPH_MAX_ITERATIONS  Max loop iterations (default: 5)
#   RALPH_WORKSPACE     Workspace directory (default: /workspace)
#   RALPH_PROMPT_FILE   Path to prompt markdown file (default: $AI_HOME/systems/prompts/ralph.md)
#   RALPH_STATUS_FILE   Path to status file; agent should write "Status: done" or "Status: blocked" (default: $RALPH_WORKSPACE/status.md)
#   RALPH_MODEL         Model name to pass to the CLI (optional; defaults by CLI:
#                       claude=haiku, opencode/kilo=minimax/MiniMax-M2.5)
#   RALPH_ITERATION_TIMEOUT  Max seconds for one CLI run (default: 600, 0 disables timeout)
#
# Example (env):
#   export RALPH_CLI=claude RALPH_MAX_ITERATIONS=10
#   ralph
#
# Example (CLI args):
#   ralph --cli opencode --max-iterations 10 --workspace /workspace
#
# Example (Docker with env):
#   docker run -e RALPH_CLI=opencode -e RALPH_MAX_ITERATIONS=5 -v $(pwd):/workspace ...
#
# Example (pass-through options to the CLI):
#   ralph --cli claude -- --model sonnet --no-chrome
#

set -e

# Defaults from env (can be overridden by args)
CLI="${RALPH_CLI:-}"
MAX_ITERATIONS="${RALPH_MAX_ITERATIONS:-5}"
WORKSPACE="${RALPH_WORKSPACE:-/workspace}"
PROMPT_FILE="${RALPH_PROMPT_FILE:-}"
STATUS_FILE="${RALPH_STATUS_FILE:-}"
MODEL="${RALPH_MODEL:-}"
AI_HOME="${AI_HOME:-$HOME/.ai}"
TASKS_FILE="${WORKSPACE}/tasks.md"
ITERATION_TIMEOUT="${RALPH_ITERATION_TIMEOUT:-600}"

# Extra arguments to pass through to the underlying CLI (set after --)
PASSTHROUGH=()

usage() {
  cat <<'EOF'
Usage: ralph [options] [--] [cli-extra-args...]

Options:
  -c, --cli <name>         CLI to run: claude, opencode, or kilo (required unless RALPH_CLI is set)
  -n, --max-iterations <n> Max loop iterations (default: 5)
  -w, --workspace <path>   Workspace directory (default: /workspace)
  -p, --prompt-file <path> Path to prompt file (default: $AI_HOME/systems/prompts/ralph.md)
  -s, --status-file <path> Path to status file for done/blocked (default: <workspace>/status.md)
  -m, --model <model>      Model to use (default: claude=haiku, opencode/kilo=minimax/MiniMax-M2.5)
  -t, --iteration-timeout <seconds>  Max seconds for one CLI run (default: 600, 0 disables timeout)
  -h, --help               Show this help

Everything after -- is passed as extra arguments to the underlying CLI (e.g. --model sonnet).

Environment variables (same names with RALPH_ prefix): RALPH_CLI, RALPH_MAX_ITERATIONS,
  RALPH_WORKSPACE, RALPH_PROMPT_FILE, RALPH_STATUS_FILE, RALPH_MODEL,
  RALPH_ITERATION_TIMEOUT.
EOF
  exit 0
}

# Parse command line; everything after -- goes into PASSTHROUGH
while [ $# -gt 0 ]; do
  case "$1" in
    --)
      shift
      PASSTHROUGH=("$@")
      break
      ;;
    -c|--cli)
      CLI="$2"
      shift 2
      ;;
    -n|--max-iterations)
      MAX_ITERATIONS="$2"
      shift 2
      ;;
    -w|--workspace)
      WORKSPACE="$2"
      shift 2
      ;;
    -p|--prompt-file)
      PROMPT_FILE="$2"
      shift 2
      ;;
    -s|--status-file)
      STATUS_FILE="$2"
      shift 2
      ;;
    -m|--model)
      MODEL="$2"
      shift 2
      ;;
    -t|--iteration-timeout)
      ITERATION_TIMEOUT="$2"
      shift 2
      ;;
    -h|--help)
      usage
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      ;;
    *)
      echo "Unexpected argument: $1 (use -- before extra CLI args)" >&2
      usage
      ;;
  esac
done

# Resolve defaults: prompt in harness systems/prompts; status in workspace
[ -z "$PROMPT_FILE" ] && PROMPT_FILE="${AI_HOME}/systems/prompts/ralph.md"
[ -z "$STATUS_FILE" ] && STATUS_FILE="${WORKSPACE}/status.md"

# Validate
if [ -z "$CLI" ]; then
  echo "Error: CLI is required. Set RALPH_CLI or use --cli (claude, opencode, or kilo)." >&2
  exit 1
fi

case "$CLI" in
  claude|opencode|kilo) ;;
  *)
    echo "Error: Invalid CLI '$CLI'. Use claude, opencode, or kilo." >&2
    exit 1
    ;;
esac

if [ -z "$MODEL" ]; then
  case "$CLI" in
    claude) MODEL="haiku" ;;
    opencode|kilo) MODEL="minimax/MiniMax-M2.5" ;;
  esac
fi

if ! [[ "$ITERATION_TIMEOUT" =~ ^[0-9]+$ ]]; then
  echo "Error: iteration-timeout must be a non-negative integer (seconds)." >&2
  exit 1
fi

if ! [ -f "$PROMPT_FILE" ]; then
  echo "Error: Prompt file not found: $PROMPT_FILE" >&2
  exit 1
fi

# Run from workspace so relative paths in the prompt (e.g. tasks.md, status.md) work
cd "$WORKSPACE"

if [ ! -f "$TASKS_FILE" ] || [ ! -f "$STATUS_FILE" ]; then
  echo "Error: Ralph requires both files to exist before starting:" >&2
  echo "  - $TASKS_FILE" >&2
  echo "  - $STATUS_FILE" >&2
  echo "Create both files in the workspace, then rerun ralph." >&2
  exit 1
fi

iteration=0

echo "Ralph: CLI=$CLI, workspace=$WORKSPACE, max_iterations=$MAX_ITERATIONS"
echo "Prompt file: $PROMPT_FILE"
echo "Status file: $STATUS_FILE"
if [ "$ITERATION_TIMEOUT" -gt 0 ]; then
  echo "Iteration timeout: ${ITERATION_TIMEOUT}s"
else
  echo "Iteration timeout: disabled"
fi
echo ""

run_with_timeout() {
  if [ "$ITERATION_TIMEOUT" -gt 0 ]; then
    timeout --foreground "${ITERATION_TIMEOUT}s" "$@"
  else
    "$@"
  fi
}

filter_passthrough_for_cli() {
  local cli_name="$1"
  shift
  local out=()
  for arg in "$@"; do
    if [ "$cli_name" = "opencode" ] && [ "$arg" = "--auto" ]; then
      echo "Note: dropping unsupported flag '--auto' for opencode."
      continue
    fi
    out+=("$arg")
  done
  printf '%s\n' "${out[@]}"
}

has_output_format_flag() {
  for arg in "$@"; do
    case "$arg" in
      --output-format|--output-format=*)
        return 0
        ;;
    esac
  done
  return 1
}

while true; do
  iteration=$((iteration + 1))

  # Read status (e.g. "Status: working" or "Status: done")
  STATUS="working"
  if [ -f "$STATUS_FILE" ]; then
    STATUS="$(grep -o 'Status: [a-zA-Z]*' "$STATUS_FILE" 2>/dev/null | cut -d' ' -f2 || true)"
    [ -z "$STATUS" ] && STATUS="working"
  fi

  if [ "$STATUS" = "done" ] || [ "$STATUS" = "blocked" ]; then
    echo "Stopping: status is '$STATUS'"
    cat "$STATUS_FILE" 2>/dev/null || true
    break
  fi

  # If tasks are complete, set done and stop without invoking the model.
  if [ -f "$TASKS_FILE" ]; then
    if ! grep -Eq '^[[:space:]]*-[[:space:]]*\[[[:space:]]\][[:space:]]+' "$TASKS_FILE"; then
      echo "All tasks complete. Setting status to 'done' and stopping."
      echo "Status: done" > "$STATUS_FILE"
      cat "$STATUS_FILE"
      break
    fi
  fi

  if [ "$iteration" -gt "$MAX_ITERATIONS" ]; then
    echo "Max iterations ($MAX_ITERATIONS) reached. Stopping."
    break
  fi

  echo ""
  echo "=== Iteration $iteration/$MAX_ITERATIONS at $(date) ==="
  echo "Status: $STATUS"
  echo ""

  # Build and run the appropriate CLI
  case "$CLI" in
    claude)
      # Claude Code: -p for print, permission mode for non-interactive approval (no --workspace; cwd is workspace)
      ARGS=(-p --permission-mode "bypassPermissions")
      [ -n "$MODEL" ] && ARGS+=(--model "$MODEL")
      if ! has_output_format_flag "${PASSTHROUGH[@]}"; then
        ARGS+=(--output-format json)
      fi
      ARGS+=("${PASSTHROUGH[@]}")
      ARGS+=("$(cat "$PROMPT_FILE")")
      set +e
      run_with_timeout claude "${ARGS[@]}"
      cli_exit=$?
      set -e
      ;;
    opencode)
      # OpenCode: use non-interactive run mode.
      ARGS=(run)
      [ -n "$MODEL" ] && ARGS+=(-m "$MODEL")
      mapfile -t FILTERED_PASSTHROUGH < <(filter_passthrough_for_cli "opencode" "${PASSTHROUGH[@]}")
      ARGS+=("${FILTERED_PASSTHROUGH[@]}")
      ARGS+=("$(cat "$PROMPT_FILE")")
      set +e
      run_with_timeout opencode "${ARGS[@]}"
      cli_exit=$?
      set -e
      ;;
    kilo)
      # Kilo: use non-interactive run mode.
      ARGS=(run)
      [ -n "$MODEL" ] && ARGS+=(-m "$MODEL")
      ARGS+=("${PASSTHROUGH[@]}")
      ARGS+=("$(cat "$PROMPT_FILE")")
      set +e
      run_with_timeout kilo "${ARGS[@]}"
      cli_exit=$?
      set -e
      ;;
  esac

  if [ "${cli_exit:-0}" -eq 124 ]; then
    echo "Iteration timed out after ${ITERATION_TIMEOUT}s. Setting status to 'blocked' and stopping."
    echo "Status: blocked" > "$STATUS_FILE"
    cat "$STATUS_FILE"
    break
  fi
  if [ "${cli_exit:-0}" -ne 0 ]; then
    echo "CLI exited with code ${cli_exit}. Setting status to 'blocked' and stopping."
    echo "Status: blocked" > "$STATUS_FILE"
    cat "$STATUS_FILE"
    break
  fi

  sleep 2
done

echo ""
echo "Loop completed."
