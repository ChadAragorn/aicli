#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <number_of_versions>" >&2
  echo "       $0 --rm" >&2
  exit 1
fi

if [[ "$1" == "--rm" ]]; then
  if [[ -d .worktree ]]; then
    rm -rf .worktree
    echo "Removed .worktree/"
  else
    echo ".worktree/ does not exist." >&2
  fi
  exit 0
fi

if ! [[ "$1" =~ ^[1-9][0-9]*$ ]]; then
  echo "Error: argument must be a positive integer." >&2
  exit 1
fi

versions="$1"
sha="$(git rev-parse --short HEAD)"

if [[ ! -f .gitignore ]]; then
  echo '.worktree/' > .gitignore
elif ! grep -qxF '.worktree/' .gitignore; then
  echo '.worktree/' >> .gitignore
fi

for ((i = 1; i <= versions; i++)); do
  dir=".worktree/${sha}-v${i}"
  mkdir -p "$dir"
  rsync -a --exclude '.worktree/' ./ "$dir/"
done

for ((i = 1; i <= versions; i++)); do
  (
    cd ".worktree/${sha}-v${i}"
    git switch -c "${sha}-v${i}"
  )
done
